# Внешний порт приложения на удалённом сервере
APP_PORT=4173

# Необязательно: отправка обратной связи на email через https://resend.com
FEEDBACK_TO_EMAIL=
# После подтверждения своего домена в Resend укажите, например:
# FEEDBACK_FROM_EMAIL=QA Report <feedback@your-domain.ru>
FEEDBACK_FROM_EMAIL=

# API-ключ хранится не здесь, а в secrets/resend_api_key.

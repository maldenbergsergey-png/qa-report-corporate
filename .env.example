PORT=4173
APP_PORT=4173
APP_BIND_ADDRESS=127.0.0.1
NODE_ENV=production

# Локальный аккаунт работает только при NODE_ENV=development и запуске на loopback.
# DEV_LOGIN_EMAIL=admin@local.test
# DEV_LOGIN_PASSWORD=replace-with-a-local-password

# Публичный origin и доверенный reverse proxy
QA_REPORT_PUBLIC_URL=https://qa-report.company.ru
QA_REPORT_TRUST_PROXY=true

# Секреты передаются файлами и не коммитятся
AUTH_SECRET_FILE=./secrets/auth_secret
LDAP_BIND_PASSWORD_FILE=./secrets/ldap_bind_password
JIRA_OAUTH_PRIVATE_KEY_FILE=./secrets/jira_oauth_private.pem
JIRA_TOKEN_ENCRYPTION_KEY_FILE=./secrets/jira_token_encryption_key

# Только LDAPS. Fingerprint ниже — референсный CA ADV; подтвердите его для своего AD.
LDAP_URL=ldaps://10.99.20.10:636
LDAP_TLS_SERVERNAME=sister.ADV.local
LDAP_BIND_DN=
LDAP_SEARCH_BASE=DC=ADV,DC=local
LDAP_CA_FILE_HOST=./secrets/ldap_ca.pem
LDAP_CA_SHA256=AA:61:3D:15:2C:4E:1A:59:AF:A5:AF:75:4B:20:9D:8F:3E:C4:DF:63:F9:2A:E7:9B:44:5C:22:AB:7E:44:7A:58

LOGIN_MAX_FAILS_PER_ACCOUNT=5
LOGIN_MAX_FAILS_PER_IP=50
LOGIN_WINDOW_MINUTES=15

# Две Jira Data Center. Один RSA consumer key регистрируется отдельным Application Link в каждой Jira.
JIRA_OAUTH_CONSUMER_KEY=qa-report
JIRA_INSTANCES_JSON=[{"id":"jira-7","name":"Jira Legacy","version":"7.3.2","baseUrl":"https://jira7.company.ru"},{"id":"jira-8","name":"Jira Main","version":"8.11.1","baseUrl":"https://jira8.company.ru"}]
QA_JIRA_ALLOWED_ORIGINS=https://jira7.company.ru,https://jira8.company.ru
JIRA_REQUIRE_EMAIL_MATCH=true

QA_STORAGE_ENDPOINT=https://minio-buckets.adv.ru
QA_STORAGE_BUCKET=qa-tools
QA_STORAGE_REGION=us-east-1
QA_STORAGE_ACCESS_KEY_FILE_HOST=./secrets/storage_access_key
QA_STORAGE_SECRET_KEY_FILE_HOST=./secrets/storage_secret_key

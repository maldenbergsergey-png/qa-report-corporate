# Локальный порт приложения
PORT=4173
APP_PORT=4173

# Корпоративное S3-совместимое хранилище MinIO
QA_STORAGE_ENDPOINT=https://minio-buckets.adv.ru
QA_STORAGE_BUCKET=qa-tools
QA_STORAGE_REGION=us-east-1
QA_STORAGE_ACCESS_KEY=
QA_STORAGE_SECRET_KEY=

# Разрешённые адреса Jira через запятую
QA_JIRA_ALLOWED_ORIGINS=

# Включать только за доверенным корпоративным reverse proxy
QA_REPORT_TRUST_PROXY=false
QA_REPORT_TRUST_PROXY_IDENTITY=false
